# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/sales_progressor"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Your app URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ─── Dev bypass (Sprint 1 only) ───────────────────────────────────────────────
# Set to "true" to skip real auth and use the seeded demo user.
# REMOVE THIS before any production deployment.
DEV_AUTH_BYPASS="true"
DEV_AUTH_USER_EMAIL="sarah@hartwellpartners.co.uk"
