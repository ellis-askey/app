// Sales Progressor - Prisma Schema
// Sprint 1: Foundation + Transactions Core

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Agency ───────────────────────────────────────────────────────────────────

model Agency {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  transactions PropertyTransaction[]
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      UserRole @default(viewer)
  agencyId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency               Agency                @relation(fields: [agencyId], references: [id])
  assignedTransactions PropertyTransaction[] @relation("AssignedUser")

  // NextAuth session fields (extend for full auth in future sprints)
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

enum UserRole {
  admin
  sales_progressor
  negotiator
  viewer
}

// ─── PropertyTransaction ──────────────────────────────────────────────────────

model PropertyTransaction {
  id                   String            @id @default(cuid())
  propertyAddress      String
  status               TransactionStatus @default(active)
  agencyId             String
  assignedUserId       String?
  expectedExchangeDate DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  agency       Agency   @relation(fields: [agencyId], references: [id])
  assignedUser User?    @relation("AssignedUser", fields: [assignedUserId], references: [id])
  contacts     Contact[]
}

enum TransactionStatus {
  active
  on_hold
  completed
  withdrawn
}

// ─── Contact ──────────────────────────────────────────────────────────────────

model Contact {
  id                    String      @id @default(cuid())
  propertyTransactionId String
  name                  String
  phone                 String?
  email                 String?
  roleType              ContactRole
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  transaction PropertyTransaction @relation(fields: [propertyTransactionId], references: [id], onDelete: Cascade)
}

enum ContactRole {
  vendor
  purchaser
  solicitor
  broker
  other
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────
// Required by NextAuth adapter. Extend as needed in future sprints.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
