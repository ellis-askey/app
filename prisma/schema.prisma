// Sales Progressor - Prisma Schema
// Sprint 2: Milestones Engine added

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Agency ───────────────────────────────────────────────────────────────────

model Agency {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  transactions PropertyTransaction[]
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      UserRole @default(viewer)
  agencyId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency               Agency                @relation(fields: [agencyId], references: [id])
  assignedTransactions PropertyTransaction[] @relation("AssignedUser")
  milestoneCompletions MilestoneCompletion[] @relation("CompletedBy")

  // NextAuth fields
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

enum UserRole {
  admin
  sales_progressor
  negotiator
  viewer
}

// ─── PropertyTransaction ──────────────────────────────────────────────────────

model PropertyTransaction {
  id                   String            @id @default(cuid())
  propertyAddress      String
  status               TransactionStatus @default(active)
  agencyId             String
  assignedUserId       String?
  expectedExchangeDate DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  agency       Agency   @relation(fields: [agencyId], references: [id])
  assignedUser User?    @relation("AssignedUser", fields: [assignedUserId], references: [id])
  contacts     Contact[]
  milestoneCompletions MilestoneCompletion[]
}

enum TransactionStatus {
  active
  on_hold
  completed
  withdrawn
}

// ─── Contact ──────────────────────────────────────────────────────────────────

model Contact {
  id                    String      @id @default(cuid())
  propertyTransactionId String
  name                  String
  phone                 String?
  email                 String?
  roleType              ContactRole
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  transaction PropertyTransaction @relation(fields: [propertyTransactionId], references: [id], onDelete: Cascade)
}

enum ContactRole {
  vendor
  purchaser
  solicitor
  broker
  other
}

// ─── MilestoneDefinition ──────────────────────────────────────────────────────
// Template records — seeded once, never created per transaction.
// All milestones block exchange except the gate milestones (PM27/VM20)
// and post-exchange milestones (PM16/PM17/VM12/VM13).

model MilestoneDefinition {
  id             String          @id @default(cuid())
  code           String          @unique   // e.g. "PM1", "VM5"
  name           String
  side           MilestoneSide
  orderIndex     Int             // Sequence within its side (1-based)
  blocksExchange Boolean         @default(true)
  timeSensitive  Boolean         @default(false)  // Requires event_date on completion
  isExchangeGate Boolean         @default(false)  // VM20 / PM27 — unlocks only when all predecessors done
  isPostExchange Boolean         @default(false)  // PM16/PM17/VM12/VM13 — excluded from gate
  createdAt      DateTime        @default(now())

  completions    MilestoneCompletion[]
}

enum MilestoneSide {
  vendor
  purchaser
}

// ─── MilestoneCompletion ──────────────────────────────────────────────────────
// Transaction-specific completion record.
// Never deleted — use isActive = false to deactivate.
// Only isActive = true records count for logic.

model MilestoneCompletion {
  id                    String   @id @default(cuid())
  transactionId         String
  milestoneDefinitionId String
  isActive              Boolean  @default(true)
  completedAt           DateTime @default(now())   // When marked complete in system
  eventDate             DateTime?                  // Real-world event date (time-sensitive milestones only)
  isNotRequired         Boolean  @default(false)   // Explicit not-required state
  notRequiredReason     String?                    // Audit: why it was marked not required
  completedById         String?                    // Which user marked it complete
  statusReason          String?                    // Optional note on completion or deactivation
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  transaction           PropertyTransaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  milestoneDefinition   MilestoneDefinition  @relation(fields: [milestoneDefinitionId], references: [id])
  completedBy           User?                @relation("CompletedBy", fields: [completedById], references: [id])

  @@index([transactionId, milestoneDefinitionId])
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
